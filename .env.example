# Scaleway credentials
SCW_ACCESS_KEY=SCWxxxxxxxxxxxxxxxxxx
SCW_SECRET_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCW_DEFAULT_ZONE=fr-par-1

# Omni connection
OMNI_ENDPOINT=https://omni.example.com
OMNI_SERVICE_ACCOUNT_KEY=<your-service-account-key>

# Provider identity — must match the ID used when creating the Omni service account.
# Each provider instance must have a unique ID (e.g. scaleway-fr-par, scaleway-nl-ams).
PROVIDER_ID=scaleway
